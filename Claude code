  );
}

function Stars({ rating, size = 12 }) {
  return (
    <div style={{ display: "flex", gap: 2 }}>
      {[1,2,3,4,5].map(i => (
        <svg key={i} width={size} height={size} viewBox="0 0 24 24" fill={i <= rating ? "#fbbf24" : "none"} stroke={i <= rating ? "#fbbf24" : "#374151"} strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
          <path d={icons.star} />
        </svg>
      ))}
