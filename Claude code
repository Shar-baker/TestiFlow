                        <div><p style={{ fontSize: 12, fontWeight: 600, color: "#fff", margin: 0 }}>{t.name}</p><p style={{ fontSize: 10, color: "#6b7280", margin: 0 }}>{t.role} · {t.company}</p></div>
                      </div>
                      <Badge color={t.status === "approved" ? "green" : t.status === "pending" ? "amber" : "red"}>{t.status}</Badge>
                    </div>
                    <Stars rating={t.rating} size={11} />
                    <p style={{ fontSize: 11, color: "#9ca3af", margin: "8px 0 0", lineHeight: 1.5, overflow: "hidden", display: "-webkit-box", WebkitLineClamp: 3, WebkitBoxOrient: "vertical" }}>"{t.message}"</p>
                    {t.status === "pending" && (
                      <div style={{ display: "flex", gap: 6, marginTop: 12 }}>
                        <Btn variant="danger" size="sm" style={{ flex: 1 }} onClick={() => handleReject(t.id)}><Icon d={icons.x} size={11} /> Reject</Btn>
                        <Btn variant="success" size="sm" style={{ flex: 1 }} onClick={() => handleApprove(t.id)}><Icon d={icons.check} size={11} /> Approve</Btn>
                      </div>
                    )}
                    <div style={{ marginTop: 10, fontSize: 10, color: "#4b5563" }}>{t.date}</div>
                  </div>
                ))}
              </div>
            </div>
          </>
        )}

        {/* ── SETTINGS ────────────────────────────────────────────────────────── */}
        {view === "settings" && (
          <>
            <DashHeader title="Settings" subtitle="Manage your account and subscription" />
            <div style={{ padding: 24 }}>
              <div style={{ display: "flex", gap: 4, marginBottom: 24 }}>
                {["Billing", "Account", "API"].map(tab => (
                  <div key={tab} onClick={() => setSettingsTab(tab)} style={{ padding: "8px 16px", borderRadius: 12, cursor: "pointer", fontSize: 12, fontWeight: 600, background: settingsTab === tab ? "rgba(255,255,255,0.08)" : "transparent", color: settingsTab === tab ? "#fff" : "#6b7280", transition: "all 0.15s" }}>{tab}</div>
                ))}
              </div>
              {settingsTab === "Billing" && (
                <div>
                  <div style={{ background: "#10101a", border: "1px solid rgba(255,255,255,0.08)", borderRadius: 18, padding: 20, marginBottom: 24 }}>
                    <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 12 }}>
                      <div><p style={{ fontSize: 13, fontWeight: 600, color: "#fff", margin: 0 }}>Current Plan</p><p style={{ fontSize: 11, color: "#6b7280", margin: "2px 0 0" }}>Free tier</p></div>
                      <Badge color="gray">Free</Badge>
                    </div>
                    {[{ label: "Testimonials", val: "3 / 5", pct: 60 }, { label: "Walls", val: "1 / 1", pct: 100 }].map(bar => (
                      <div key={bar.label} style={{ marginBottom: 10 }}>
                        <div style={{ display: "flex", justifyContent: "space-between", fontSize: 11, color: "#9ca3af", marginBottom: 4 }}><span>{bar.label}</span><span>{bar.val}</span></div>
                        <div style={{ background: "rgba(255,255,255,0.08)", borderRadius: 999, height: 5 }}>
                          <div style={{ background: "linear-gradient(90deg, #8b5cf6, #6366f1)", width: `${bar.pct}%`, height: "100%", borderRadius: 999 }} />
                        </div>
                      </div>
                    ))}
                  </div>
                  <div style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: 14 }}>
                    {[
                      { name: "Free", price: 0, feats: ["1 wall", "5 testimonials", "Basic widgets"], current: true, highlight: false },
                      { name: "Pro", price: 29, feats: ["10 walls", "200 testimonials", "All layouts", "Remove branding", "Video testimonials"], current: false, highlight: true },
                      { name: "Agency", price: 99, feats: ["Unlimited walls", "Unlimited testimonials", "White-label", "API access"], current: false, highlight: false },
                    ].map(tier => (
                      <div key={tier.name} style={{ background: tier.highlight ? "linear-gradient(160deg, rgba(139,92,246,0.18), rgba(99,102,241,0.08))" : "#10101a", border: `1px solid ${tier.highlight ? "rgba(139,92,246,0.4)" : "rgba(255,255,255,0.08)"}`, borderRadius: 18, padding: 20, position: "relative" }}>
                        {tier.highlight && <div style={{ position: "absolute", top: -9, left: "50%", transform: "translateX(-50%)", background: "linear-gradient(135deg, #8b5cf6, #6366f1)", color: "#fff", fontSize: 9, fontWeight: 700, padding: "3px 10px", borderRadius: 999 }}>POPULAR</div>}
                        <p style={{ fontFamily: "'Syne', sans-serif", fontWeight: 700, color: "#fff", margin: "0 0 6px" }}>{tier.name}</p>
                        <div style={{ marginBottom: 14 }}>{tier.price === 0 ? <span style={{ fontSize: 22, fontWeight: 800, color: "#fff", fontFamily: "'Syne', sans-serif" }}>Free</span> : <><span style={{ fontSize: 22, fontWeight: 800, color: "#fff", fontFamily: "'Syne', sans-serif" }}>${tier.price}</span><span style={{ fontSize: 11, color: "#6b7280" }}>/mo</span></>}</div>
                        <ul style={{ listStyle: "none", padding: 0, margin: "0 0 16px", display: "flex", flexDirection: "column", gap: 6 }}>
                          {tier.feats.map(f => <li key={f} style={{ display: "flex", gap: 7, fontSize: 11, color: "#d1d5db" }}><Icon d={icons.check} size={11} style={{ color: "#a78bfa", flexShrink: 0, marginTop: 1 }} />{f}</li>)}
                        </ul>
                        {tier.current ? (
                          <div style={{ background: "rgba(255,255,255,0.04)", borderRadius: 10, padding: "8px", textAlign: "center", fontSize: 11, color: "#6b7280", border: "1px solid rgba(255,255,255,0.06)" }}>Current plan</div>
                        ) : (
                          <Btn variant={tier.highlight ? "primary" : "ghost"} fullWidth size="sm">Upgrade →</Btn>
                        )}
                      </div>
                    ))}
                  </div>
                </div>
              )}
              {settingsTab === "Account" && (
                <div style={{ background: "#10101a", border: "1px solid rgba(255,255,255,0.08)", borderRadius: 18, padding: 24, maxWidth: 480 }}>
                  {[{ l: "Full name", v: "John Doe", t: "text" }, { l: "Email", v: "john@example.com", t: "email" }].map(f => (
                    <div key={f.l} style={{ marginBottom: 16 }}>
                      <label style={S.label}>{f.l}</label>
                      <input type={f.t} defaultValue={f.v} style={S.input} />
                    </div>
                  ))}
                  <Btn variant="primary">Save changes</Btn>
                </div>
              )}
              {settingsTab === "API" && (
                <div style={{ background: "#10101a", border: "1px solid rgba(255,255,255,0.08)", borderRadius: 18, padding: 24, maxWidth: 520 }}>
                  <p style={{ fontSize: 13, fontWeight: 600, color: "#fff", margin: "0 0 6px" }}>API Key</p>
                  <p style={{ fontSize: 12, color: "#9ca3af", margin: "0 0 14px" }}>Use this key to interact with the TestiFlow API.</p>
                  <div style={{ display: "flex", gap: 8 }}>
                    <code style={{ flex: 1, background: "#0a0a0e", border: "1px solid rgba(255,255,255,0.08)", borderRadius: 10, padding: "10px 14px", fontSize: 11, color: "#9ca3af", fontFamily: "monospace", overflow: "hidden" }}>tf_live_sk_••••••••••••••••••••••••••••••</code>
                    <Btn variant="ghost" size="sm" onClick={handleCopy}>{copied ? "✓" : <><Icon d={icons.copy} size={12} /> Copy</>}</Btn>
                  </div>
                  <p style={{ fontSize: 11, color: "#6b7280", marginTop: 10 }}>API access requires Pro or Agency plan.</p>
                </div>
              )}
            </div>
          </>
        )}
      </main>
    </div>
  );
}
